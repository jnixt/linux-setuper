#!/usr/bin/env bash

# ==============================================================================
#  count-packages
#  Counts installed packages from every detected package manager.
#
#  Usage:
#    count-packages       — prints total package count only
#    count-packages -v    — prints per-manager breakdown  (e.g. 312 (pacman), 8 (flatpak))
# ==============================================================================

show_all=false

while getopts "v" opt; do
    case "$opt" in
        v) show_all=true ;;
        *) ;;
    esac
done

parts=()
total=0

# --- Native package managers (mutually exclusive; pick the first one found) ---

if command -v pacman >/dev/null 2>&1; then
    n=$(pacman -Qq 2>/dev/null | wc -l)
    total=$((total + n))
    parts+=("${n} (pacman)")

    # AUR helpers — count *foreign* packages not tracked by pacman itself
    for helper in yay paru trizen aurman; do
        if command -v "$helper" >/dev/null 2>&1; then
            aur=$(pacman -Qm 2>/dev/null | wc -l)
            if [[ $aur -gt 0 ]]; then
                parts+=("${aur} (aur)")
                # AUR pkgs are already in the pacman -Qq total, so don't add to total
            fi
            break
        fi
    done

elif command -v dpkg >/dev/null 2>&1; then
    n=$(dpkg -l 2>/dev/null | grep -c '^ii' || echo 0)
    total=$((total + n))
    parts+=("${n} (apt)")

elif command -v rpm >/dev/null 2>&1; then
    n=$(rpm -qa 2>/dev/null | wc -l)
    total=$((total + n))
    # Label by the front-end if detectable
    if command -v dnf >/dev/null 2>&1; then
        parts+=("${n} (dnf)")
    elif command -v zypper >/dev/null 2>&1; then
        parts+=("${n} (zypper)")
    else
        parts+=("${n} (rpm)")
    fi
fi

# --- Universal / overlay package managers ---

if command -v flatpak >/dev/null 2>&1; then
    n=$(flatpak list 2>/dev/null | wc -l)
    if [[ $n -gt 0 ]]; then
        total=$((total + n))
        parts+=("${n} (flatpak)")
    fi
fi

if command -v snap >/dev/null 2>&1; then
    # snap list always prints a header line — skip it
    n=$(snap list 2>/dev/null | tail -n +2 | wc -l)
    if [[ $n -gt 0 ]]; then
        total=$((total + n))
        parts+=("${n} (snap)")
    fi
fi

if command -v brew >/dev/null 2>&1; then
    n=$(brew list 2>/dev/null | wc -l)
    if [[ $n -gt 0 ]]; then
        total=$((total + n))
        parts+=("${n} (brew)")
    fi
fi

# --- Output ---

if [[ ${#parts[@]} -eq 0 ]]; then
    echo "unknown"
    exit 1
fi

if $show_all; then
    # Join parts with ", "
    out="${parts[0]}"
    for ((i = 1; i < ${#parts[@]}; i++)); do
        out+=", ${parts[$i]}"
    done
    echo "$out"
else
    echo "$total"
fi
